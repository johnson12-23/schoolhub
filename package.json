{
  "name": "schoolhub",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "install:all": "npm install --workspaces",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build:frontend": "npm --workspace frontend run build",
    "seed:backend": "npm --workspace backend run seed"
  }
}
